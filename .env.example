# ============================================================
# Kavalx Advanced Fraud Detection & Banking Security
# Environment Variables Template
# ============================================================
# Copy this file to .env and fill in production values.
#   cp .env.example .env
# ============================================================

# ── Security ───────────────────────────────────────────────
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
API_KEY_SALT=change-me-salt-16chars

# ── PostgreSQL ─────────────────────────────────────────────
PG_DSN=postgresql://kavalx:kavalx@postgres:5432/kavalx
PG_POOL_MIN=2
PG_POOL_MAX=20

# ── Memgraph ──────────────────────────────────────────────
MEMGRAPH_URL=bolt://memgraph:7687

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# ── Kafka ─────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── Milvus (Vector DB) ───────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530

# ── TorchServe (TGN, APK Models) ─────────────────────────
TORCHSERVE_URL=http://torchserve:8080

# ── vLLM (AMADP LLM Backbone) ────────────────────────────
VLLM_URL=http://vllm:8090

# ── TFLite (PINN Biometric Model) ────────────────────────
TFLITE_MODEL_PATH=/models/pinn_bio.tflite

# ── Post-Quantum Cryptography ────────────────────────────
PQC_KEY_PATH=/keys/dilithium_private.key

# ── Hyperledger Fabric ────────────────────────────────────
FABRIC_PEER_URL=grpc://fabric-peer:7051

# ── IndicTrans (Multilingual NLP) ────────────────────────
INDICTRANS_URL=http://indictrans:8070

# ── Tor Proxy (OSINT Dark-Web) ───────────────────────────
TOR_PROXY=socks5h://tor:9050

# ── Telegram OSINT ───────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── MISP Threat Intelligence ─────────────────────────────
MISP_URL=https://misp.local
MISP_API_KEY=

# ── Soufflé Datalog (Compliance Rules) ───────────────────
DATALOG_RULES_PATH=/rules/rbi_ontology.dl
